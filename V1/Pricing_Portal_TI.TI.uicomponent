/></uxc:BoOperation></uxc:EventHandler><uxc:EventHandler id="uTJnhxbBpaoXHt01_WsPbG" name="OnCancel"><uxc:RestartClient id="LZRlnh82dq2J32fGU5BAoG" name="CancelOperation"/></uxc:EventHandler><uxc:EventHandler id="DoWxA9JiAqcwfd9jlC8f2W" name="OnSave"><uxc:WindowAction id="ttQ2XxS8Vaw3sCLNWR_mim" name="SaveOperation" action="Save"/></uxc:EventHandler><uxc:EventHandler id="cn$1yHYYnawUpCGnMQjJOW" name="PreviewHandler"><uxc:FirePlug id="JULNGqShwKoQ6Jfpbea_$G" name="Operation" outPlug="PreviewOutport"/></uxc:EventHandler><uxc:EventHandler id="jQGr3dOJuKoXmJWfCS_CBW" name="Remove_Row"><uxc:ListOperation id="lZfIbrK_7aAHykXhDryMGm" name="Operation" operation="RemoveRow" targetList="/Root/DataList"/></uxc:EventHandler><uxc:EventHandler id="n8155wmvGaIjPNj2e6wRwm" name="SendBackForRevisiom"><uxc:BoAction id="MqiwYf7bqaQ7IJMphTCmPm" name="Operation" proxyName="Pricing_Portal" esrNamespace="http://refsystems.sap.com/YTFS8S0TY_" actionPath="-&gt;SendBackForRevision_APP1" instanceBinding="/Root" type="multiple"><base:PropertyBag id="6RWDvxUsh4c8nF0scPBqfW"><base:Property id="IffevovMeKAwLQNLeuF95m" name="UITEXTID" value=""/><base:Property id="ZxNxeDZK5KYm0efNHj727W" name="XBUT" value=""/><base:Property id="DTJXZZZj0qILMaRg9_LcUW" name="XTOL" value=""/></base:PropertyBag></uxc:BoAction></uxc:EventHandler><uxc:EventHandler id="f5oApgIxlq28oxXykNHnsG" name="SendForproval"><uxc:BoAction id="F4dJO9oP44_$3zn2bL0de0" name="Operation" proxyName="Pricing_Portal" esrNamespace="http://refsystems.sap.com/YTFS8S0TY_" actionPath="-&gt;SubmitForApproval_APP1" instanceBinding="/Root" type="multiple"><base:PropertyBag id="50COOYpaTK6TDn_b2fuE5m"><base:Property id="rIbmFOlyv4Ev_g9Y8_NXzG" name="UITEXTID" value=""/><base:Property id="MQj9fOGe5qUUQW2B3IobBW" name="XBUT" value=""/><base:Property id="pdFRMAqRyqQsqi8v2RoavW" name="XTOL" value=""/></base:PropertyBag></uxc:BoAction></uxc:EventHandler><uxc:EventHandler id="W5xgn0fii4kUckAMc0jZwm" name="SetProcessStatusMode"><uxc:Script id="mQ_M3qyRRqUKUcuZ5ikldG" name="Operation" blocking="true"><uxc:Source><![CDATA[if ($data.Pricing_Portal.ApprovalStatus == '4')
$data.Pricing_Portal.ProcessStatusMode = '2'
else 
$data.Pricing_Portal.ProcessStatusMode = '3'
end
                    
]]></uxc:Source><uxc:JScriptSource><![CDATA[ if ( ( ScriptContext.compare(  DataWrapper.Get( "Pricing_Portal" ).Get( "ApprovalStatus" ).GetValue( ),  "4", "EQ" ) ) ) {
 DataWrapper.Get( "Pricing_Portal" ).Get( "ProcessStatusMode" ).SetValue( "2" ); }
